<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="48x48" href="/assets/favicon/favicon-48x48.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">

  {% set canonicalUrl = "https://fabriziovinciguerraph.com" + page.url %}
  {% set socialImage = ogImage or "https://fabriziovinciguerraph.com/assets/images/social/og-image.jpg" %}

  <title>{{ title }}</title>

  <meta name="description" content="{{ description }}">
  <meta name="author" content="Fabrizio Vinciguerra">

  {% if robots %}
    <meta name="robots" content="{{ robots }}">
  {% else %}
    <meta name="robots" content="index, follow, max-image-preview:large">
  {% endif %}

  <link rel="canonical" href="{{ canonicalUrl }}">

  <!-- OPEN GRAPH -->

  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:url" content="{{ canonicalUrl }}">
  <meta property="og:site_name" content="Fabrizio Vinciguerra Photography">
  <meta property="og:locale" content="en_US">
  <meta property="og:image" content="{{ socialImage }}">
  <meta
    property="og:image:alt"
    content="{{ ogImageAlt or 'Fine art landscape photography by Fabrizio Vinciguerra' }}"
  >

  <!-- TWITTER / X -->

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="{{ socialImage }}">
  <meta
    name="twitter:image:alt"
    content="{{ ogImageAlt or 'Fine art landscape photography by Fabrizio Vinciguerra' }}"
  >

  <!-- PERFORMANCE -->

  {% if page.url == "/" %}
    <link rel="preload" as="image" href="/assets/images/home.jpg">
  {% endif %}

  <!-- STRUCTURED DATA -->

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://fabriziovinciguerraph.com/#website",
        "url": "https://fabriziovinciguerraph.com/",
        "name": "Fabrizio Vinciguerra Photography",
        "description": "Fine art landscape photography exploring light, silence, nature and memory.",
        "inLanguage": "en",
        "publisher": {
          "@id": "https://fabriziovinciguerraph.com/#fabrizio-vinciguerra"
        }
      },
      {
        "@type": "Person",
        "@id": "https://fabriziovinciguerraph.com/#fabrizio-vinciguerra",
        "name": "Fabrizio Vinciguerra",
        "url": "https://fabriziovinciguerraph.com/",
        "image": {
          "@type": "ImageObject",
          "url": "https://fabriziovinciguerraph.com/assets/images/social/og-image.jpg",
          "contentUrl": "https://fabriziovinciguerraph.com/assets/images/social/og-image.jpg"
        },
        "jobTitle": "Fine Art Landscape Photographer",
        "description": "Sicilian fine art landscape photographer and visual storyteller exploring light, silence, volcanic landscapes and memory.",
        "sameAs": [
          "https://www.instagram.com/fabriziovinciguerraph",
          "https://www.facebook.com/fabriziovinciguerraph"
        ],
        "award": [
          "35AWARDS Top 200 Landscape — 2025",
          "35AWARDS Official Catalogue Selection — 2025",
          "35AWARDS Top 100 Landscape — Daytime — 2026",
          "35AWARDS Top 35 Italy — 2026"
        ],
        "knowsAbout": [
          "Fine art landscape photography",
          "Sicilian landscape photography",
          "Mount Etna photography",
          "Volcanic landscape photography",
          "Forest photography",
          "Waterfall photography",
          "Nature photography",
          "Travel photography",
          "Visual storytelling"
        ],
        "nationality": {
          "@type": "Country",
          "name": "Italy"
        },
        "homeLocation": {
          "@type": "Place",
          "name": "Sicily, Italy"
        }
      },
      {
        "@type": "WebPage",
        "@id": "{{ canonicalUrl }}#webpage",
        "url": "{{ canonicalUrl }}",
        "name": "{{ title }}",
        "description": "{{ description }}",
        "isPartOf": {
          "@id": "https://fabriziovinciguerraph.com/#website"
        },
        "about": {
          "@id": "https://fabriziovinciguerraph.com/#fabrizio-vinciguerra"
        },
        "primaryImageOfPage": {
          "@type": "ImageObject",
          "url": "{{ socialImage }}",
          "contentUrl": "{{ socialImage }}"
        },
        "inLanguage": "en"
      }
    ]
  }
  </script>

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

  <div
    class="preloader"
    aria-hidden="true"
  >

    <div class="preloader-content">

      <span class="preloader-mark">
        FV
      </span>

      <span class="preloader-line"></span>

      <span class="preloader-label">
        Photography
      </span>

    </div>

  </div>

  <div
    class="custom-cursor"
    aria-hidden="true"
  ></div>

  <div
    class="page-transition"
    aria-hidden="true"
  ></div>

  {% include "header.njk" %}

  <main>

    {{ content | safe }}

  </main>

  {% include "footer.njk" %}

  <div
  class="lightbox"
  id="lightbox"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-label="Photograph viewer"
>
  <button
    class="lightbox-close"
    type="button"
    aria-label="Close photograph viewer"
  >
    ×
  </button>

  <button
    class="lightbox-prev"
    type="button"
    aria-label="Previous photograph"
  >
    ‹
  </button>

  <img src="" alt="">

  <button
    class="lightbox-next"
    type="button"
    aria-label="Next photograph"
  >
    ›
  </button>

  <div
    class="lightbox-caption"
    aria-live="polite"
  ></div>

  <div
    class="lightbox-counter"
    id="lightboxCounter"
    aria-live="polite"
  ></div>
</div>

<script type="module" src="/js/main.js"></script>

</body>

</html>