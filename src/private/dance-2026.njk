---
layout: layout.njk
title: "Dance Recital 2026 | Private Gallery"
description: "Private gallery for client photo selection."
---

<section class="page-hero">
  <p class="subtitle">Private Gallery</p>

  <h1>Dance Recital 2026</h1>

  <p>
    A private selection gallery for viewing and choosing your favourite photographs.
  </p>
</section>

<section class="private-gallery">

  {% for photo in dance2026 %}
    <figure class="private-photo {{ photo.class }} reveal">
      <img 
        src="{{ photo.src }}" 
        alt="{{ photo.alt }}"
        class="lightbox-image"
        data-full="{{ photo.src }}"
         data-title="Photo {{ loop.index }}"
        >
      <figcaption>Photo {{ loop.index }}</figcaption>
    </figure>
  {% endfor %}

</section>