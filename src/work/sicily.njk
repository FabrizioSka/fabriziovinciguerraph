<section class="collection-hero">
  <img src="/assets/images/sicily.PNG" alt="Sicily">

  <div class="collection-hero-content">
    <p class="subtitle">Collection 03</p>
    <h1>Sicily</h1>
    <p>A personal landscape shaped by memory, light and volcanic earth.</p>
  </div>
</section>

<section class="fine-art-story">

  <div class="story-text">
    <p>
      A land of lava, ancient forests and Mediterranean light.
    </p>
  </div>

  {% for photo in sicily %}
    <figure class="story-image {{ photo.class }} reveal">
      <img src="{{ photo.src }}" alt="{{ photo.alt }}">
    </figure>
  {% endfor %}

</section>

