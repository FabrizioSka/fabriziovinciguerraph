<section class="collection-hero">

  <img
    src="/assets/images/woods.jpg"
    alt="Atmospheric forest landscape from the Woods and Silence fine art photography collection"
  >

  <div class="collection-hero-content">

    <p class="subtitle">Collection 01</p>

    <h1>Woods &amp; Silence</h1>

    <p>
      Where silence becomes visible.
    </p>

  </div>

</section>

<section class="fine-art-story">

  <div class="story-text">

    <p>
      In the quiet of the woods, light becomes slower.
      Every branch, shadow and reflection seems to hold its breath.
    </p>

  </div>

  {% for photo in woods %}

    <figure class="story-image {{ photo.class }} reveal">

      <img
        src="{{ photo.src }}"
        alt="{{ photo.alt }}"
        loading="lazy"
        decoding="async"
        class="lightbox-image"
        data-full="{{ photo.src }}"
        data-title=""
      >

    </figure>

  {% endfor %}

</section>