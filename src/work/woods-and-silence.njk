{% set gallery = woods %}
{% set galleryName = "Woods & Silence — Fine Art Forest Photography" %}
{% set galleryDescription = "A fine art photography collection exploring ancient trees, forests, woodland light, silence and memory." %}

{% include "image-gallery-schema.njk" %}

{% set breadcrumbItems = [
  {
    name: "Home",
    url: "https://www.fabriziovinciguerraph.com/"
  },
  {
    name: "Work",
    url: "https://www.fabriziovinciguerraph.com/work/"
  },
  {
    name: "Woods & Silence",
    url: "https://www.fabriziovinciguerraph.com/work/woods-and-silence/"
  }
] %}

{% include "breadcrumb-schema.njk" %}

<section class="collection-hero">

  <img
    src="/assets/images/woods.jpg"
    alt="Atmospheric forest landscape from the Woods and Silence fine art photography collection"
  >

  <div class="collection-hero-content">

    <p class="subtitle">Collection 01</p>

    <h1>Woods &amp; Silence</h1>

    <p>
      Where silence becomes visible.
    </p>

  </div>

</section>

<section class="fine-art-story waterfall-story">

  <div class="travel-quote reveal">
    <p>
      Some trees become landscapes themselves.<br>
      Their branches hold time, silence and memory.
    </p>
  </div>

  {% for photo in woods %}

    {% if loop.index == 4 %}

      <div class="travel-quote reveal">
        <p>
          Every forest speaks differently.<br>
          Some through shadow, others through light.
        </p>
      </div>

    {% endif %}

    {% if loop.index == 7 %}

      <div class="travel-quote reveal">
        <p>
          The oldest trees do not ask to be noticed.<br>
          They simply remain.
        </p>
      </div>

    {% endif %}

    <figure class="story-image travel-image {{ photo.class }} reveal">

      <img
        src="{{ photo.src }}"
        alt="{{ photo.alt }}"
        loading="lazy"
        decoding="async"
        class="lightbox-image"
        data-full="{{ photo.src }}"
        data-title="{{ photo.title }}"
      >

    </figure>

  {% endfor %}

  <div class="travel-closing reveal">
    <p>
      In the quiet of the woods,<br>
      even time learns to slow down.
    </p>
  </div>

</section>